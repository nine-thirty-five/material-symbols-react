  "scripts": {
    "prepare": "husky",
    "generate": "tsx src/generate.ts",
    "generate:sample": "tsx src/generate.ts --limit 80",
    "metadata": "tsx src/generate.ts --metadata-only",
    "clean": "rimraf dist",
    "prebuild": "npm run clean",
    "build": "npm run generate",
    "typecheck": "tsc --noEmit",
    "test": "vitest run",
    "lint": "eslint .",
    "format": "prettier --write \"{src,example/src}/**/*.{js,ts,jsx,tsx}\"",
    "codemod:v1-to-v2": "jscodeshift -t codemods/v1-to-v2.cjs --parser tsx",
    "verify:package": "publint --strict && attw --pack ."
  },
